        "harness_name": "web_search"
      },
      "input_schema": {
        "additionalProperties": false,
        "properties": {
          "query": {
            "description": "search query",
            "type": "string"
          }
        },
        "required": [
          "query"
        ],
        "type": "object"
      },
      "name": "web-search",
      "output_schema": {
        "additionalProperties": false,
        "properties": {
          "results": {
            "items": {
              "type": "object"
            },
            "type": "array"
          }
        },
        "required": [
          "results"
        ],
        "type": "object"
      },
      "policy_status": "review",
      "side_effect": "network"
    },
    {
      "auth_scopes": [
        "fs:write"
      ],
      "description": "Create or overwrite a file at a path (also archive/SQLite entries).",
