        "harness_name": "write"
      },
      "input_schema": {
        "additionalProperties": false,
        "properties": {
          "content": {
            "description": "full file contents",
            "type": "string"
          },
          "path": {
            "description": "destination path",
            "type": "string"
          }
        },
        "required": [
          "path",
          "content"
        ],
        "type": "object"
      },
      "name": "write",
      "policy_status": "allowed",
      "side_effect": "write"
    },
