        "additionalProperties": false,
        "properties": {
          "message": {
            "description": "plain prose",
            "type": "string"
          },
          "op": {
            "enum": [
              "send",
              "wait",
              "inbox",
              "list"
            ],
            "type": "string"
          },
          "replyTo": {
            "description": "correlate a reply",
            "type": "string"
          },
          "to": {
            "description": "peer id or 'all'",
            "type": "string"
          }
        },
        "required": [
          "op"
        ],
        "type": "object"
      },
      "name": "irc",
      "policy_status": "allowed",
      "side_effect": "none"
    },
    {
