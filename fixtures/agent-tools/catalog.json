        "additionalProperties": false,
        "properties": {
          "items": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "op": {
            "description": "init|start|done|drop|rm|append|view",
            "type": "string"
          },
          "task": {
            "description": "verbatim task content",
            "type": "string"
          }
        },
        "required": [
          "op"
        ],
        "type": "object"
      },
      "name": "todo",
      "policy_status": "allowed",
      "side_effect": "write"
    },
    {
      "auth_scopes": [
        "net:read"
      ],
      "description": "Search the web for up-to-date information beyond the knowledge cutoff.",
