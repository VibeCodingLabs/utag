{
  "extensions": {
    "harness_name": "glob"
  },
  "name": "glob",
  "description": "Glob files and directories via fast pattern matching.",
  "input_schema": {
    "type": "object",
    "properties": {
      "path": {
        "type": "string",
        "description": "glob, file, or directory; ';'-delimited for many"
      },
      "gitignore": {
        "type": "boolean"
      },
      "hidden": {
        "type": "boolean"
      }
    },
    "required": [
      "path"
    ],
    "additionalProperties": false
  },
  "side_effect": "read",
  "auth_scopes": [
    "fs:read"
  ],
  "policy_status": "allowed"
}
