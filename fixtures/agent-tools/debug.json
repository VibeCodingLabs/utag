{
  "extensions": {
    "harness_name": "debug"
  },
  "name": "debug",
  "description": "Debugger access: launch/attach, breakpoints, stepping, inspection.",
  "input_schema": {
    "type": "object",
    "properties": {
      "action": {
        "type": "string",
        "description": "launch|attach|continue|step_over|…"
      },
      "program": {
        "type": "string",
        "description": "target"
      },
      "adapter": {
        "type": "string",
        "description": "debugpy|gdb|lldb-dap|dlv dap"
      }
    },
    "required": [
      "action"
    ],
    "additionalProperties": false
  },
  "side_effect": "write",
  "auth_scopes": [
    "exec",
    "process:control"
  ],
  "policy_status": "allowed"
}
