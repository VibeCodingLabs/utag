# syntax=docker/dockerfile:1
FROM golang:1.24-alpine AS build
WORKDIR /src
COPY control-plane/ .
RUN CGO_ENABLED=0 go build -ldflags="-s -w" -o /utag-control-plane .

FROM gcr.io/distroless/static-debian12:nonroot
COPY --from=build /utag-control-plane /utag-control-plane
USER nonroot
EXPOSE 8080
ENTRYPOINT ["/utag-control-plane", "serve"]
