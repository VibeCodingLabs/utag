{
  "$defs": {
    "TestSummary": {
      "additionalProperties": false,
      "properties": {
        "extensions": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Extensions"
        },
        "failed": {
          "minimum": 0,
          "title": "Failed",
          "type": "integer"
        },
        "passed": {
          "minimum": 0,
          "title": "Passed",
          "type": "integer"
        },
        "skipped": {
          "minimum": 0,
          "title": "Skipped",
          "type": "integer"
        }
      },
      "required": [
        "passed",
        "failed",
        "skipped"
      ],
      "title": "TestSummary",
      "type": "object"
    }
  },
  "$id": "https://utag.dev/schemas/release-manifest.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "artifacts": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Artifacts",
      "type": "array"
    },
    "commit_sha": {
      "pattern": "^[a-f0-9]{7,40}$",
      "title": "Commit Sha",
      "type": "string"
    },
    "extensions": {
      "anyOf": [
        {
          "additionalProperties": true,
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Extensions"
    },
    "gates": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Gates",
      "type": "array"
    },
    "test_summary": {
      "$ref": "#/$defs/TestSummary"
    },
    "version": {
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "title": "Version",
      "type": "string"
    }
  },
  "required": [
    "version",
    "commit_sha",
    "test_summary"
  ],
  "title": "ReleaseManifest",
  "type": "object"
}
