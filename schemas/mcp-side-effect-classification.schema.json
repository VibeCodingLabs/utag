{
  "$defs": {
    "SideEffect": {
      "enum": [
        "none",
        "read",
        "write",
        "destructive",
        "network"
      ],
      "title": "SideEffect",
      "type": "string"
    }
  },
  "$id": "https://utag.dev/schemas/mcp-side-effect-classification.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "classification": {
      "$ref": "#/$defs/SideEffect"
    },
    "extensions": {
      "anyOf": [
        {
          "additionalProperties": true,
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Extensions"
    },
    "rationale": {
      "minLength": 1,
      "title": "Rationale",
      "type": "string"
    },
    "tool": {
      "pattern": "^[a-z0-9][a-z0-9._/-]*$",
      "title": "Tool",
      "type": "string"
    }
  },
  "required": [
    "tool",
    "classification",
    "rationale"
  ],
  "title": "MCPSideEffectClassification",
  "type": "object"
}
