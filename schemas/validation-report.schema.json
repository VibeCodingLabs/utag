{
  "$defs": {
    "Severity": {
      "enum": [
        "info",
        "warn",
        "error"
      ],
      "title": "Severity",
      "type": "string"
    },
    "ValidationFinding": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "pattern": "^[a-z0-9][a-z0-9._/-]*$",
          "title": "Code",
          "type": "string"
        },
        "extensions": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Extensions"
        },
        "message": {
          "minLength": 1,
          "title": "Message",
          "type": "string"
        },
        "path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Path"
        },
        "pointer": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Pointer"
        },
        "severity": {
          "$ref": "#/$defs/Severity"
        }
      },
      "required": [
        "severity",
        "code",
        "message"
      ],
      "title": "ValidationFinding",
      "type": "object"
    }
  },
  "$id": "https://utag.dev/schemas/validation-report.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "artifact_id": {
      "pattern": "^[a-z0-9][a-z0-9._/-]*$",
      "title": "Artifact Id",
      "type": "string"
    },
    "extensions": {
      "anyOf": [
        {
          "additionalProperties": true,
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Extensions"
    },
    "findings": {
      "default": [],
      "items": {
        "$ref": "#/$defs/ValidationFinding"
      },
      "title": "Findings",
      "type": "array"
    },
    "run_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Run Id"
    },
    "span_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Span Id"
    },
    "valid": {
      "title": "Valid",
      "type": "boolean"
    }
  },
  "required": [
    "artifact_id",
    "valid"
  ],
  "title": "ValidationReport",
  "type": "object"
}
