{
  "$id": "https://utag.dev/schemas/capability-manifest.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "extensions": {
      "anyOf": [
        {
          "additionalProperties": true,
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Extensions"
    },
    "id": {
      "pattern": "^[a-z0-9][a-z0-9._/-]*$",
      "title": "Id",
      "type": "string"
    },
    "name": {
      "title": "Name",
      "type": "string"
    },
    "provided_by": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Provided By",
      "type": "array"
    },
    "required_tools": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Required Tools",
      "type": "array"
    }
  },
  "required": [
    "id",
    "name"
  ],
  "title": "CapabilityManifest",
  "type": "object"
}
