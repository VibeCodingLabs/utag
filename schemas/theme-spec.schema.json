{
  "$id": "https://utag.dev/schemas/theme-spec.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "extensions": {
      "anyOf": [
        {
          "additionalProperties": true,
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Extensions"
    },
    "name": {
      "pattern": "^[a-z0-9][a-z0-9._/-]*$",
      "title": "Name",
      "type": "string"
    },
    "tokens": {
      "additionalProperties": {
        "type": "string"
      },
      "default": {},
      "title": "Tokens",
      "type": "object"
    }
  },
  "required": [
    "name"
  ],
  "title": "ThemeSpec",
  "type": "object"
}
