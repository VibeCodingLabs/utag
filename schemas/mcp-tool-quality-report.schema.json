{
  "$id": "https://utag.dev/schemas/mcp-tool-quality-report.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "extensions": {
      "anyOf": [
        {
          "additionalProperties": true,
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Extensions"
    },
    "findings": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Findings",
      "type": "array"
    },
    "has_auth_hints": {
      "default": false,
      "title": "Has Auth Hints",
      "type": "boolean"
    },
    "has_output_schema": {
      "default": false,
      "title": "Has Output Schema",
      "type": "boolean"
    },
    "score": {
      "maximum": 1,
      "minimum": 0,
      "title": "Score",
      "type": "number"
    },
    "tool": {
      "pattern": "^[a-z0-9][a-z0-9._/-]*$",
      "title": "Tool",
      "type": "string"
    }
  },
  "required": [
    "tool",
    "score"
  ],
  "title": "MCPToolQualityReport",
  "type": "object"
}
