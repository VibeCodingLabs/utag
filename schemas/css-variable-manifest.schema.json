{
  "$defs": {
    "CssVariable": {
      "additionalProperties": false,
      "properties": {
        "extensions": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Extensions"
        },
        "name": {
          "pattern": "^--[a-z][a-z0-9-]*$",
          "title": "Name",
          "type": "string"
        },
        "value": {
          "minLength": 1,
          "title": "Value",
          "type": "string"
        }
      },
      "required": [
        "name",
        "value"
      ],
      "title": "CssVariable",
      "type": "object"
    }
  },
  "$id": "https://utag.dev/schemas/css-variable-manifest.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "extensions": {
      "anyOf": [
        {
          "additionalProperties": true,
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Extensions"
    },
    "file": {
      "minLength": 1,
      "title": "File",
      "type": "string"
    },
    "source_design": {
      "pattern": "^[a-z0-9][a-z0-9._/-]*$",
      "title": "Source Design",
      "type": "string"
    },
    "variables": {
      "items": {
        "$ref": "#/$defs/CssVariable"
      },
      "title": "Variables",
      "type": "array"
    }
  },
  "required": [
    "file",
    "variables",
    "source_design"
  ],
  "title": "CssVariableManifest",
  "type": "object"
}
