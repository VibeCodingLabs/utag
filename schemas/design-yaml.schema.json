    "AccessibilityContract": {
      "additionalProperties": false,
      "properties": {
        "extensions": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Extensions"
        },
        "keyboardRequired": {
          "title": "Keyboardrequired",
          "type": "boolean"
        },
        "minContrast": {
          "$ref": "#/$defs/ContrastLevel"
        }
      },
      "required": [
        "minContrast",
        "keyboardRequired"
      ],
      "title": "AccessibilityContract",
      "type": "object"
    },
    "Brand": {
      "additionalProperties": false,
      "properties": {
        "extensions": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Extensions"
        },
        "name": {
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "voice": {
          "default": "",
          "title": "Voice",
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "title": "Brand",
      "type": "object"
    },
    "ComponentSpec": {
