    },
    "extensions": {
      "anyOf": [
        {
          "additionalProperties": true,
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Extensions"
    },
    "id": {
      "pattern": "^[a-z0-9][a-z0-9._/-]*$",
      "title": "Id",
      "type": "string"
    },
    "interactions": {
      "default": [],
      "items": {
        "$ref": "#/$defs/InteractionSpec"
      },
      "title": "Interactions",
      "type": "array"
