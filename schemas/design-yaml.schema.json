      "type": "object"
    },
    "tokens": {
      "$ref": "#/$defs/DesignTokens",
      "default": {
        "color": {},
        "extensions": null,
        "motion": {},
        "radius": {},
        "shadow": {},
        "spacing": {},
        "typography": {}
