  "$id": "https://utag.dev/schemas/design-yaml.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Canonical design source-of-truth (design.yaml).",
  "properties": {
    "accessibility": {
