{
  "$id": "https://utag.dev/schemas/eval-result.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "case_id": {
      "pattern": "^[a-z0-9][a-z0-9._/-]*$",
      "title": "Case Id",
      "type": "string"
    },
    "extensions": {
      "anyOf": [
        {
          "additionalProperties": true,
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Extensions"
    },
    "passed": {
      "title": "Passed",
      "type": "boolean"
    },
    "score": {
      "anyOf": [
        {
          "maximum": 1,
          "minimum": 0,
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Score"
    }
  },
  "required": [
    "case_id",
    "passed"
  ],
  "title": "EvalResult",
  "type": "object"
}
