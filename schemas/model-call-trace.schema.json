{
  "$id": "https://utag.dev/schemas/model-call-trace.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "cost_usd": {
      "anyOf": [
        {
          "minimum": 0,
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Cost Usd"
    },
    "extensions": {
      "anyOf": [
        {
          "additionalProperties": true,
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Extensions"
    },
    "input_tokens": {
      "anyOf": [
        {
          "minimum": 0,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Input Tokens"
    },
    "latency_ms": {
      "anyOf": [
        {
          "minimum": 0,
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Latency Ms"
    },
    "model": {
      "minLength": 1,
      "title": "Model",
      "type": "string"
    },
    "output_sha256": {
      "pattern": "^[a-f0-9]{64}$",
      "title": "Output Sha256",
      "type": "string"
    },
    "output_tokens": {
      "anyOf": [
        {
          "minimum": 0,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Output Tokens"
    },
    "prompt_sha256": {
      "pattern": "^[a-f0-9]{64}$",
      "title": "Prompt Sha256",
      "type": "string"
    },
    "provider": {
      "pattern": "^[a-z0-9][a-z0-9._/-]*$",
      "title": "Provider",
      "type": "string"
    },
    "run_id": {
      "pattern": "^[a-z0-9][a-z0-9._/-]*$",
      "title": "Run Id",
      "type": "string"
    }
  },
  "required": [
    "run_id",
    "provider",
    "model",
    "prompt_sha256",
    "output_sha256"
  ],
  "title": "ModelCallTrace",
  "type": "object"
}
