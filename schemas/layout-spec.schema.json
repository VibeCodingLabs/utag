{
  "$id": "https://utag.dev/schemas/layout-spec.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "extensions": {
      "anyOf": [
        {
          "additionalProperties": true,
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Extensions"
    },
    "id": {
      "pattern": "^[a-z0-9][a-z0-9._/-]*$",
      "title": "Id",
      "type": "string"
    },
    "regions": {
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "title": "Regions",
      "type": "array"
    }
  },
  "required": [
    "id",
    "regions"
  ],
  "title": "LayoutSpec",
  "type": "object"
}
