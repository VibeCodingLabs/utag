{
  "$id": "https://utag.dev/schemas/mcp-prompt-contract.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "arguments": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Arguments",
      "type": "array"
    },
    "description": {
      "minLength": 1,
      "title": "Description",
      "type": "string"
    },
    "extensions": {
      "anyOf": [
        {
          "additionalProperties": true,
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Extensions"
    },
    "name": {
      "pattern": "^[a-z0-9][a-z0-9._/-]*$",
      "title": "Name",
      "type": "string"
    }
  },
  "required": [
    "name",
    "description"
  ],
  "title": "MCPPromptContract",
  "type": "object"
}
