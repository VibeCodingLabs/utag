{
  "$id": "https://utag.dev/schemas/mcp-resource-contract.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "description": {
      "minLength": 1,
      "title": "Description",
      "type": "string"
    },
    "extensions": {
      "anyOf": [
        {
          "additionalProperties": true,
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Extensions"
    },
    "mime_type": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Mime Type"
    },
    "uri": {
      "minLength": 1,
      "title": "Uri",
      "type": "string"
    }
  },
  "required": [
    "uri",
    "description"
  ],
  "title": "MCPResourceContract",
  "type": "object"
}
