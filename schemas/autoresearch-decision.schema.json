{
  "$id": "https://utag.dev/schemas/autoresearch-decision.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "decision": {
      "minLength": 1,
      "title": "Decision",
      "type": "string"
    },
    "extensions": {
      "anyOf": [
        {
          "additionalProperties": true,
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Extensions"
    },
    "id": {
      "pattern": "^[a-z0-9][a-z0-9._/-]*$",
      "title": "Id",
      "type": "string"
    },
    "rationale": {
      "minLength": 1,
      "title": "Rationale",
      "type": "string"
    }
  },
  "required": [
    "id",
    "decision",
    "rationale"
  ],
  "title": "AutoresearchDecision",
  "type": "object"
}
