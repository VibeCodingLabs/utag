{
  "$defs": {
    "LogLevel": {
      "enum": [
        "debug",
        "info",
        "warn",
        "error"
      ],
      "title": "LogLevel",
      "type": "string"
    }
  },
  "$id": "https://utag.dev/schemas/log-record.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "extensions": {
      "anyOf": [
        {
          "additionalProperties": true,
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Extensions"
    },
    "level": {
      "$ref": "#/$defs/LogLevel"
    },
    "message": {
      "minLength": 1,
      "title": "Message",
      "type": "string"
    },
    "run_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Run Id"
    },
    "span_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Span Id"
    }
  },
  "required": [
    "level",
    "message"
  ],
  "title": "LogRecord",
  "type": "object"
}
