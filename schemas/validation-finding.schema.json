{
  "$defs": {
    "Severity": {
      "enum": [
        "info",
        "warn",
        "error"
      ],
      "title": "Severity",
      "type": "string"
    }
  },
  "$id": "https://utag.dev/schemas/validation-finding.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "code": {
      "pattern": "^[a-z0-9][a-z0-9._/-]*$",
      "title": "Code",
      "type": "string"
    },
    "extensions": {
      "anyOf": [
        {
          "additionalProperties": true,
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Extensions"
    },
    "message": {
      "minLength": 1,
      "title": "Message",
      "type": "string"
    },
    "path": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Path"
    },
    "pointer": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Pointer"
    },
    "severity": {
      "$ref": "#/$defs/Severity"
    }
  },
  "required": [
    "severity",
    "code",
    "message"
  ],
  "title": "ValidationFinding",
  "type": "object"
}
