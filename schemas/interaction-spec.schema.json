{
  "$id": "https://utag.dev/schemas/interaction-spec.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "extensions": {
      "anyOf": [
        {
          "additionalProperties": true,
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Extensions"
    },
    "id": {
      "pattern": "^[a-z0-9][a-z0-9._/-]*$",
      "title": "Id",
      "type": "string"
    },
    "source": {
      "pattern": "^[a-z0-9][a-z0-9._/-]*$",
      "title": "Source",
      "type": "string"
    },
    "target": {
      "pattern": "^[a-z0-9][a-z0-9._/-]*$",
      "title": "Target",
      "type": "string"
    }
  },
  "required": [
    "id",
    "source",
    "target"
  ],
  "title": "InteractionSpec",
  "type": "object"
}
