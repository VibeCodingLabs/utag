{
  "$defs": {
    "JobStatus": {
      "enum": [
        "queued",
        "running",
        "completed",
        "failed",
        "dead-letter"
      ],
      "title": "JobStatus",
      "type": "string"
    }
  },
  "$id": "https://utag.dev/schemas/worker-job-trace.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "extensions": {
      "anyOf": [
        {
          "additionalProperties": true,
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Extensions"
    },
    "job_id": {
      "pattern": "^[a-z0-9][a-z0-9._/-]*$",
      "title": "Job Id",
      "type": "string"
    },
    "run_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Run Id"
    },
    "status": {
      "$ref": "#/$defs/JobStatus"
    }
  },
  "required": [
    "job_id",
    "status"
  ],
  "title": "WorkerJobTrace",
  "type": "object"
}
