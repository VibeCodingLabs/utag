{
  "$id": "https://utag.dev/schemas/resource-contract.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Per-job resource limits (wolfram-kb principle: every expensive job carries one).",
  "properties": {
    "allow_remote": {
      "default": false,
      "title": "Allow Remote",
      "type": "boolean"
    },
    "concurrency_class": {
      "default": "default",
      "pattern": "^[a-z0-9][a-z0-9._/-]*$",
      "title": "Concurrency Class",
      "type": "string"
    },
    "degradation_policy": {
      "default": "fail",
      "pattern": "^(fail|queue|degrade)$",
      "title": "Degradation Policy",
      "type": "string"
    },
    "extensions": {
      "anyOf": [
        {
          "additionalProperties": true,
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Extensions"
    },
    "max_memory_bytes": {
      "minimum": 1,
      "title": "Max Memory Bytes",
      "type": "integer"
    },
    "max_output_bytes": {
      "minimum": 1,
      "title": "Max Output Bytes",
      "type": "integer"
    },
    "max_vram_bytes": {
      "default": 0,
      "minimum": 0,
      "title": "Max Vram Bytes",
      "type": "integer"
    },
    "max_wall_time_s": {
      "minimum": 1,
      "title": "Max Wall Time S",
      "type": "integer"
    }
  },
  "required": [
    "max_memory_bytes",
    "max_wall_time_s",
    "max_output_bytes"
  ],
  "title": "ResourceContract",
  "type": "object"
}
