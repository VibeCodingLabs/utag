{
  "$id": "https://utag.dev/schemas/run-event.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "attributes": {
      "additionalProperties": {
        "type": "string"
      },
      "default": {},
      "title": "Attributes",
      "type": "object"
    },
    "extensions": {
      "anyOf": [
        {
          "additionalProperties": true,
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Extensions"
    },
    "name": {
      "pattern": "^utag\\.[a-z][a-z0-9._-]*$",
      "title": "Name",
      "type": "string"
    },
    "run_id": {
      "pattern": "^[a-z0-9][a-z0-9._/-]*$",
      "title": "Run Id",
      "type": "string"
    }
  },
  "required": [
    "run_id",
    "name"
  ],
  "title": "RunEvent",
  "type": "object"
}
